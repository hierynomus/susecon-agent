@host = http://10.29.10.51:30080
# @name initialize
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": { "name": "curl-test", "version": "1.0" }
  }
}

###
@mcp-token = {{initialize.response.headers.Mcp-Session-Id}}
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{mcp-token}}

{"jsonrpc":"2.0","method":"notifications/initialized"}


###
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{mcp-token}}

{"jsonrpc":"2.0","id":2,"method":"tools/list"}

###

POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{mcp-token}}

{
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "recommend_sessions",
      "arguments": { "topic": "AI", "max_results": 3 }
    }
}